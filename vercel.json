{
  "buildCommand": "npm run build --workspace frontend",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/public/service-categories", "destination": "/api/public-service-categories" },
    { "source": "/api/public/services", "destination": "/api/public-services" }
  ]
}